# macOS
.DS_Store

# Benchmark working data (regenerated by the harness)
corpus-build/
results/logs/
results/archives/
results/work/

# Tool acquisition areas (downloaded/built at setup time; provenance recorded
# in tools/README.md with URLs and SHA-256 checksums)
tools/src/
tools/bin/
tools/wine/prefix/
tools/wine/downloads/
tools/dos/downloads/
tools/dos/apps/

# Python
__pycache__/
*.pyc
.venv/

# LaTeX intermediates (paper.pdf itself is committed)
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
